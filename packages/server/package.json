{
  "name": "@betcoin/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@betcoin/shared": "*",
    "@betcoin/config": "*",
    "@prisma/client": "^6.5.0",
    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "bullmq": "^5.30.0",
    "ioredis": "^5.4.0",
    "zod": "^3.24.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  }
}
